# experiments/supconrun_selfsupsupcon1-1_elasticc2_100pos_3000neg_tinyermidshallow6_1.env
#

# Data
MALLORN_TRAIN_PARQUET=/ceph/hpc/home/contardog/ELASTICC2/mallorn-like/training_ELAsTiCC2_subtrain_100pos_3000neg.parq
MALLORN_TEST_PARQUET=/ceph/hpc/home/contardog/ELASTICC2/mallorn-like/training_ELAsTiCC2_subval_100pos_3000neg.parq
MALLORN_MODEL_NAME=/ceph/hpc/home/contardog/MALLORN/SupCon_logs/ELASTICC2_mallornlike/supconrun_selfsupsupcon_1-1/_elasticc2_100pos_3000neg_tinyermidshallow6_1weight

# Model
MALLORN_MODEL_SIZE=tinyer-midshallow_6
MALLORN_PROJECTION_DIM=32
MALLORN_CLS_CONTRASTIVE_DIM=32



# Training
MALLORN_PRETRAIN_EPOCHS=4000
MALLORN_PRETRAIN_BATCH_SIZE=64
MALLORN_PRETRAIN_GRAD_CLIP=1

# Contrastive
MALLORN_TEMPERATURE=0.15 #?
# not used: MALLORN_MASK_RATIO_CONTRASTIVE=1.0
MALLORN_CLASS_CONTRAST_WEIGHT=1.0
MALLORN_AUG_CONTRAST_WEIGHT=0.0
MALLORN_RECON_WEIGHT=1.0

MALLORN_UNSUP_IN_DENOMINATOR=false   # 

# Sampler
MALLORN_K_POSITIVE_BATCH=6

# Set to true on cluster
MALLORN_VEGA=true